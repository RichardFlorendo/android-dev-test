<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="90dp">

    <TextView
        android:id="@+id/pokemon_id_TV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pokemon_id"
        android:textStyle="bold"
        android:layout_alignParentStart="true"
        android:layout_marginStart="20dp"
        android:layout_marginTop="40dp"
        android:gravity="center">
    </TextView>

    <ImageView
        android:id="@+id/pokemon_pic_IV"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:contentDescription="@string/pokemon_image_desc"
        android:src="@android:drawable/picture_frame"
        android:layout_toEndOf="@id/pokemon_id_TV"
        android:layout_marginTop="12dp">
    </ImageView>
    
    <TextView
        android:id="@+id/pokemon_name_TV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/pokemon_pic_IV"
        android:textStyle="bold"
        android:text="@string/pokemon_name_text"
        android:layout_alignParentTop="true"
        android:layout_marginStart="20dp"
        android:layout_marginTop="40dp"
        android:gravity="center">
    </TextView>
</RelativeLayout>